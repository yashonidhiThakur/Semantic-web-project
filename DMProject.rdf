<?xml version="1.0"?>
<rdf:RDF xmlns="http://dm-project.org/multi-portal-xcommerce/"
     xml:base="http://dm-project.org/multi-portal-xcommerce/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://dm-project.org/multi-portal-xcommerce"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://dm-project.org/multi-portal-xcommerce#Sells -->

    <owl:ObjectProperty rdf:about="http://dm-project.org/multi-portal-xcommerce#Sells">
        <owl:inverseOf rdf:resource="http://dm-project.org/multi-portal-xcommerce#hasSeller"/>
        <rdfs:domain rdf:resource="http://dm-project.org/multi-portal-xcommerce#Seller"/>
        <rdfs:range rdf:resource="http://dm-project.org/multi-portal-xcommerce#Product"/>
    </owl:ObjectProperty>
    


    <!-- http://dm-project.org/multi-portal-xcommerce#hasSeller -->

    <owl:ObjectProperty rdf:about="http://dm-project.org/multi-portal-xcommerce#hasSeller">
        <rdfs:domain rdf:resource="http://dm-project.org/multi-portal-xcommerce#Product"/>
        <rdfs:range rdf:resource="http://dm-project.org/multi-portal-xcommerce#Seller"/>
    </owl:ObjectProperty>
    


    <!-- http://dm-project.org/multi-portal-xcommerce#hasoffer -->

    <owl:ObjectProperty rdf:about="http://dm-project.org/multi-portal-xcommerce#hasoffer">
        <owl:inverseOf rdf:resource="http://dm-project.org/multi-portal-xcommerce#offerprovidedby"/>
        <rdfs:domain rdf:resource="http://dm-project.org/multi-portal-xcommerce#Seller"/>
        <rdfs:range rdf:resource="http://dm-project.org/multi-portal-xcommerce#Offer"/>
    </owl:ObjectProperty>
    


    <!-- http://dm-project.org/multi-portal-xcommerce#offerprovidedby -->

    <owl:ObjectProperty rdf:about="http://dm-project.org/multi-portal-xcommerce#offerprovidedby">
        <rdfs:domain rdf:resource="http://dm-project.org/multi-portal-xcommerce#Offer"/>
        <rdfs:range rdf:resource="http://dm-project.org/multi-portal-xcommerce#Seller"/>
    </owl:ObjectProperty>
    


    <!-- http://dm-project.org/multi-portal-xcommerce#onProduct -->

    <owl:ObjectProperty rdf:about="http://dm-project.org/multi-portal-xcommerce#onProduct">
        <rdfs:domain rdf:resource="http://dm-project.org/multi-portal-xcommerce#Offer"/>
        <rdfs:range rdf:resource="http://dm-project.org/multi-portal-xcommerce#Product"/>
    </owl:ObjectProperty>
    


