    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/athira/ontologies/2026/xcommerce#appliesToProduct -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#appliesToProduct">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#Deals&amp;Offers"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#Products"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athira/ontologies/2026/xcommerce#has_Seller -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#has_Seller">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#sellsProduct"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#Products"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#Seller"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athira/ontologies/2026/xcommerce#hasoffer -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#hasoffer">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#offered_by"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#Seller"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#Deals&amp;Offers"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athira/ontologies/2026/xcommerce#offered_by -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#offered_by">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#Deals&amp;Offers"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#Seller"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/athira/ontologies/2026/xcommerce#sellsProduct -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#sellsProduct">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#Seller"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athira/ontologies/2026/xcommerce#Products"/>
    </owl:ObjectProperty>
    


