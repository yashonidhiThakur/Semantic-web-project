     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:flipkart="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart">
        <rdfs:comment>This is the flipkart schema</rdfs:comment>
    </owl:Ontology>
    


