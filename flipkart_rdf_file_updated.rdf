    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart#Ddscount -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart#Ddscount"/>
    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart#contact_info -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart#contact_info"/>
    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart#end_date -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart#end_date"/>
    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart#name -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart#name"/>
    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart#ratings -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart#ratings"/>
    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart#start_date -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart#start_date"/>
    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/Ddscount -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/Ddscount"/>
    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/Product_ID -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/Product_ID"/>
    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/camers_resolution -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/camers_resolution"/>
    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/ratings -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/ratings"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/gives_offer -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/gives_offer">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/seller"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/offer"/>
        <rdfs:comment>seller gives offers</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/has_offer -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/has_offer">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/product"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/offer"/>
        <rdfs:comment>product has offer</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/offer -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/offer">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/offer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/product"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/offer_given -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/offer_given">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/offer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/seller"/>
        <rdfs:comment>offer is given by sellers</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/sells -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/sells">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/seller"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/product"/>
        <rdfs:comment>seller sells products</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/sold_by -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/sold_by">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/product"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/hp/ontologies/2026/1/flipkart/seller"/>
        <rdfs:comment>product is sold by seller</rdfs:comment>
    </owl:ObjectProperty>
    


